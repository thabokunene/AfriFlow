{#
  @file corridor_pnl_report.jinja2
  @description Renders a per-corridor P&L summary report showing revenue
               generated by each active payment corridor for a corporate client.

               A "corridor" is a source-country → destination-country payment
               route. For each corridor we report:
                 - Total payment volume (ZAR)
                 - Transaction count
                 - Average fee rate applied
                 - Total fee revenue earned
                 - FX spread revenue (if any forward or spot trades occurred)
                 - Insurance premium revenue (if coverage was placed)
                 - Net corridor P&L

               This report helps the RM understand which corridors drive the
               most revenue and which are under-monetised.

               Expected context variables:
                 client_name  — str: canonical client name
                 report_date  — str: ISO date of the reporting period
                 corridors    — list of corridor dicts, each containing:
                                  source_country, destination_country,
                                  payment_volume_zar, transaction_count,
                                  avg_fee_rate_pct, fee_revenue_zar,
                                  fx_revenue_zar, insurance_revenue_zar,
                                  net_pnl_zar
                 total_pnl_zar — float: sum of net_pnl_zar across all corridors
  @author Thabo Kunene
  @created 2026-03-18
#}

{# ============================================================ #}
{# SECTION: Report header                                      #}
{# ============================================================ #}
{{ "=" * 70 }}
CORRIDOR P&L REPORT: {{ client_name }}
Report Date: {{ report_date }}
{{ "=" * 70 }}

{# ============================================================ #}
{# SECTION: Corridor detail rows                               #}
{# Iterates over each corridor dict in the corridors list.     #}
{# loop.index provides a 1-based row number.                   #}
{# ============================================================ #}
{% for corridor in corridors %}
{{ loop.index }}. {{ corridor.source_country }} → {{ corridor.destination_country }}
   Volume      : R{{ "{:,.0f}".format(corridor.payment_volume_zar) }}
   Transactions: {{ corridor.transaction_count }}
   Avg Fee Rate: {{ "%.3f"|format(corridor.avg_fee_rate_pct) }}%
   Fee Revenue : R{{ "{:,.0f}".format(corridor.fee_revenue_zar) }}
   FX Revenue  : R{{ "{:,.0f}".format(corridor.fx_revenue_zar) }}
   Insurance   : R{{ "{:,.0f}".format(corridor.insurance_revenue_zar) }}
   {# -------------------------------------------------------- #}
   {# Net P&L line: bold separator helps RM scan quickly       #}
   {# -------------------------------------------------------- #}
   NET P&L     : R{{ "{:,.0f}".format(corridor.net_pnl_zar) }}
   {{ "-" * 60 }}
{% else %}
{# Fallback: rendered if corridors list is empty               #}
  No active corridors for this client in the reporting period.
{% endfor %}

{# ============================================================ #}
{# SECTION: Totals footer                                      #}
{# ============================================================ #}
{{ "=" * 70 }}
TOTAL CORRIDOR P&L: R{{ "{:,.0f}".format(total_pnl_zar) }}
{{ "=" * 70 }}
