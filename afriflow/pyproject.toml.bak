[project]
name = "afriflow"
version = "0.1.0"
description = "Cross divisional data integration platform demonstrating unified client intelligence across CIB, Forex, Insurance, Cell Network, and Personal Banking domains for pan African financial services. This is a concept demonstration, not a sanctioned project."
readme = "README.md"
license = {text = "MIT"}
requires-python = ">=3.10"
authors = [
    {name = "Thabo Kunene"},
]

[project.optional-dependencies]
dev = [
    "pytest>=7.4",
    "pytest-cov>=4.1",
    "ruff>=0.1",
    "mypy>=1.5",
    "pre-commit>=3.4",
]
streaming = [
    "confluent-kafka>=2.2",
    "apache-flink>=1.17",
    "avro-python3>=1.10",
]
batch = [
    "pyspark>=3.4",
    "delta-spark>=2.4",
    "dbt-core>=1.6",
    "dbt-spark>=1.6",
]
ml = [
    "scikit-learn>=1.3",
    "xgboost>=1.7",
    "shap>=0.42",
    "pandas>=2.0",
    "numpy>=1.24",
]
serving = [
    "fastapi>=0.100",
    "uvicorn>=0.23",
    "httpx>=0.24",
]
quality = [
    "great-expectations>=0.17",
]

[tool.ruff]
line-length = 72
target-version = "py310"

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-v --cov=domains --cov=integration --cov=governance"

[tool.mypy]
python_version = "3.10"
warn_return_any = true
warn_unused_configs = true
